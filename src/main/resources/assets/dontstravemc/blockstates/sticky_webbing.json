{
  "multipart": [
    {
      "when": { "north": "true" },
      "apply": { "model": "dontstravemc:block/sticky_webbing", "uvlock": true }
    },
    {
      "when": { "east": "true" },
      "apply": { "model": "dontstravemc:block/sticky_webbing", "y": 90, "uvlock": true }
    },
    {
      "when": { "south": "true" },
      "apply": { "model": "dontstravemc:block/sticky_webbing", "y": 180, "uvlock": true }
    },
    {
      "when": { "west": "true" },
      "apply": { "model": "dontstravemc:block/sticky_webbing", "y": 270, "uvlock": true }
    },
    {
      "when": { "up": "true" },
      "apply": { "model": "dontstravemc:block/sticky_webbing", "x": 270, "uvlock": true }
    },
    {
      "when": { "down": "true" },
      "apply": { "model": "dontstravemc:block/sticky_webbing", "x": 90, "uvlock": true }
    }
  ]
}